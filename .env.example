# PhishLab configuration — copy this file to ".env" (in this folder OR in backend/) and fill in what you
# have. EVERYTHING here is OPTIONAL: PhishLab runs with none of it (features that need a key just degrade).
# The .env is gitignored, so your secrets never get committed. Real OS environment variables win over it.

# ── Email intake (forward suspicious mail here → auto-analyse the ATTACHMENT) ──────────────────────
# A dedicated SOC Gmail with IMAP enabled + an App Password (Google Account → Security → App passwords).
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Only mail from these senders is acted on (comma-separated; a bare "@domain" trusts a whole domain).
# Everything else (UptimeRobot / Google Alerts / LinkedIn / newsletters) is ignored.
MAIL_INTAKE_SENDERS=soc-alerts@example.com
# MAIL_POLL_INTERVAL=30

# ── Enrichment API keys (each is optional; the lookup is skipped/degraded without it) ─────────────
VIRUSTOTAL_KEY=
GOOGLE_SAFEBROWSING_KEY=
ABUSEIPDB_KEY=
PHISHTANK_APP_KEY=
# The reporter handle stamped on PhishTank submissions (your PhishTank account username).
# PHISH_PHISHTANK_USER=

# ── Decloak vantages ──────────────────────────────────────────────────────────────────────────────
# Tor is fetched by Install.bat and started by the launcher automatically (no config needed).
# NordVPN is an OPTIONAL extra vantage — service credentials from your Nord dashboard (NOT your login).
NORDVPN_SERVICE_USER=
NORDVPN_SERVICE_PASS=
# PHISH_NORD_SERVERS=nl,se,us

# ── Identity used on takedown / rating-request forms (VT/FortiGuard/etc.) ─────────────────────────
PHISH_REPORTER_EMAIL=soc-alerts@example.com
# PHISH_REPORTER_NAME=SOC Team
# PHISH_REPORTER_PHONE=

# ── Decoy identity typed into phishing login forms (fake — never a real account) ──────────────────
# PHISH_FAKE_EMAIL=abelrtsmith@gmail.com
# PHISH_FAKE_USER=abelrtsmith
# PHISH_FAKE_PW=Nv3r-R3al!P4ss

# ── Engine / server (rarely needed) ───────────────────────────────────────────────────────────────
# PHISH_ENGINE=seleniumbase        # seleniumbase (default, solves Cloudflare) | camoufox (Firefox backup)
# PORT=8090
# PHISH_ALLOWED_HOSTS=             # extra Host headers allowed to reach the console (comma-separated)
